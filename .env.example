# .env.example — Copiar para .env e preencher
# NÃO commitar o ficheiro .env

# ─── Django ──────────────────────────────────────────────────────────────────
# Gerar com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ─── MySQL ───────────────────────────────────────────────────────────────────
# Configurar conforme a instalação local (XAMPP, WAMP, etc.)
# O nome da BD ('earthconsulters') é definido em etl_portal/settings.py
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=

# ─── Meilisearch (opcional) ───────────────────────────────────────────────────
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key
