# .env.example — Copiar para .env e preencher
# NÃO commitar o ficheiro .env

# ─── Django ──────────────────────────────────────────────────────────────────
# Gerar com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ─── Base de Dados ───────────────────────────────────────────────────────────
# DB_ENGINE=sqlite   → usa SQLite local (db_demo.sqlite3) — zero config, ideal para demo
# DB_ENGINE=mysql    → usa MySQL/MariaDB com as credenciais abaixo
DB_ENGINE=sqlite

# Apenas necessário se DB_ENGINE=mysql:
# DB_NAME=earthconsulters
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# ─── Meilisearch (opcional — pesquisa avançada) ───────────────────────────────
# Se não configurado, o portal usa pesquisa Django nativa
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key
